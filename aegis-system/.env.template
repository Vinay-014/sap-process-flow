# AEGIS Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# LLM API Keys
GOOGLE_API_KEY=your-google-api-key-here
GROQ_API_KEY=your-groq-api-key-here
TOGETHER_API_KEY=your-together-api-key-here

# Database (Cloud Run uses Cloud SQL Unix socket)
# For local development: postgresql+psycopg2://aegis:aegis_secure_2024@127.0.0.1:5433/aegis_db
# For Cloud Run: postgresql+psycopg2://aegis:aegis_secure_2024@/aegis_db?host=/cloudsql/YOUR_PROJECT_ID:REGION:aegis-db
DATABASE_URL=postgresql+psycopg2://aegis:aegis_secure_2024@127.0.0.1:5433/aegis_db

# LLM Model
LLM_MODEL=gemini-2.5-flash

# Red Team Threshold (0.0-1.0)
RED_TEAM_THRESHOLD=0.65
